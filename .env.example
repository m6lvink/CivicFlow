# Copy to .env

# OpenAI API key --> needed for the requirements agent (civicflow check)
OPENAI_API_KEY=sk-...

# OpenAI model for the requirements agent; default gpt-4o
OPENAI_MODEL=gpt-4o

# Max pages sent to vision per PDF upload; cost guardrail
VISION_MAX_PAGES=10

# --- API security ---
# Comma-separated keys for the X-API-Key header; empty = open endpoints (dev only)
CIVICFLOW_API_KEYS=
# Allowed browser origins for CORS; comma-separated
CIVICFLOW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allowed Host header values; comma-separated; * = any
CIVICFLOW_ALLOWED_HOSTS=*
# Per-identity request budget per minute; sliding window
CIVICFLOW_RATE_LIMIT_PER_MIN=60
# Max OpenAI vision calls per UTC day; cost guard
CIVICFLOW_OPENAI_DAILY_CALLS=50
# Max plan files per /check request
CIVICFLOW_MAX_PLAN_FILES=4
# OpenAI request timeout in seconds
CIVICFLOW_OPENAI_TIMEOUT=60

# Frontend env vars in frontend/.env.example (NEXT_PUBLIC_* is browser-exposed)
